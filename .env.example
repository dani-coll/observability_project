# Dynatrace API token for OpenTelemetry Collector
# NEVER commit this file to version control!
OTEL_API_URL=replace_with_your_otel_api_url
OTEL_API_TOKEN=replace_with_your_otel_api_token

# Your name or initials — used to namespace all service names so multiple
# participants running this project don't collide in the same Dynatrace tenant.
# Services will appear as backend-<NAMESPACE>, frontend-<NAMESPACE>, etc.
NAMESPACE=yourname
